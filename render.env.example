# Render dashboard environment variables
# Paste these values into Render -> Service -> Environment

DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
APP_STORAGE_ROOT=/tmp/voice-banking

# For a native Android app, * is acceptable.
# If you later add a browser frontend, replace * with a comma-separated allowlist.
CORS_ALLOW_ORIGINS=*
