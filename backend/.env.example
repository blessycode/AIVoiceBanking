# Local fallback if DATABASE_URL is omitted:
# DATABASE_URL=sqlite:///backend/voice_bank.db

# Supabase / hosted Postgres example:
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require

# Comma-separated list. Use * only for local testing.
CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-render-service.onrender.com

# Optional. Defaults to backend/ when unset.
APP_STORAGE_ROOT=/tmp/voice-banking
